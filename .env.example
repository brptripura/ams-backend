# ── Server Configuration ──────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/brp?appName=Cluster0
# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret — must be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<your-jwt-secret-at-least-32-chars>
JWT_EXPIRES_IN=7d

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://ams-frontend-web-niuz.onrender.com
BACKEND_URL=https://brp-mobile.onrender.com


# ── File Storage — Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Email — Option A: Firebase Auth REST API (recommended for Render) ────────
# Render blocks SMTP ports. Firebase Auth REST API uses HTTPS (port 443).
# Get your API key from Firebase Console → Project Settings → Web API Key
FIREBASE_API_KEY=<your-firebase-web-api-key>

# ── Email — Option B: Resend HTTP API ────────────────────────────────────────
# Alternative HTTP-based email (free 100 emails/day).
# RESEND_API_KEY=<your-resend-api-key>

# ── Email — Option C: SMTP (works locally / non-Render hosts) ────────────────
# If FIREBASE_API_KEY or RESEND_API_KEY is set, SMTP is ignored.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply.brpams@gmail.com
SMTP_PASS=<your-app-password>
SMTP_FROM=BRP-AMS <noreply.brpams@gmail.com>
